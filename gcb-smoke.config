/*
 * SMOKE-TEST execution profile for nf-core/sarek on Google Batch.
 * Same cloud/executor settings as gcb.config but WITHOUT the params block,
 * so the `test` profile supplies its own tiny genome + reads.
 * Use:  nextflow run nf-core/sarek -r 3.8.1 -profile test,docker -c gcb-smoke.config
 */

// Run tasks on Google Batch
process {
    executor = 'google-batch'
    resourceLimits = [ cpus: 32, memory: 120.GB, time: 24.h ]
    // Batch 5000x = infrastructure failures (VM recreated/preempted/rebooted), not data
    // errors. 50006 in particular aborted a whole cohort when it was missing (see gcb.config).
    errorStrategy   = { task.exitStatus in [8,10,14,50001,50002,50003,50004,50005,50006,50007] ? 'retry' : 'finish' }
    maxRetries      = 3   // important for Spot reclaims
}

// Pipeline working directory lives in the bucket (separate smoke-test scratch)
workDir = 'gs://intergenica-sarek-clinical/work-smoke'

google {
    project  = 'intergenica'
    location = 'us-central1'
    batch {
        spot         = true
        bootDiskSize = 150.GB
    }
}

docker.enabled = true

timeline.enabled = true
report.enabled   = true
trace.enabled    = true
dag.enabled      = true
