/*
 * Google Batch execution profile for nf-core/sarek  (clinical germline WGS)
 * Project: intergenica   Billing: Computacion-nube   Region: us-central1
 * Use:  nextflow run nf-core/sarek -profile docker -c gcb.config ...
 */

params {
    // --- defaults for this pipeline (override on the CLI as needed) ---
    genome = 'GATK.GRCh38'
    tools  = 'deepvariant,strelka,freebayes,haplotypecaller'
    // input/outdir are passed on the command line
}

// Cap concurrent tasks so a big cohort doesn't flood Batch past the region CPU quota
// (100% quota saturation starves job completion). See README "Quota preflight".
executor {
    queueSize = 40                     // ~ maxForks across the run; raise if quota is high
}

// Run tasks on Google Batch
process {
    executor = 'google-batch'
    // Per-task VM ceilings (each Sarek process gets its own right-sized Spot VM)
    resourceLimits = [ cpus: 32, memory: 120.GB, time: 24.h ]
    errorStrategy   = { task.exitStatus in [8,10,14,50001,50002] ? 'retry' : 'finish' }
    maxRetries      = 5   // Spot reclaims (exit 50001): long jobs (HaplotypeCaller) can be
                          // preempted several times, so >3 is needed to survive a bad streak.
}

// Pipeline working directory lives in the bucket
workDir = 'gs://intergenica-sarek-clinical/work'

google {
    project  = 'intergenica'
    location = 'us-central1'
    batch {
        // Spot = ~70-90% cheaper but preemptible. Long HaplotypeCaller jobs on Spot can be
        // reclaimed faster than they finish. For a reliability-critical or repeatedly-preempted
        // run, set SAREK_SPOT=false to use on-demand VMs (higher cost, no preemption).
        spot         = ((System.getenv('SAREK_SPOT') ?: 'true') == 'true')
        bootDiskSize = 150.GB          // scratch for WGS intermediates
        // serviceAccountEmail defaults to the compute SA we granted roles to
    }
}

// Containers are pulled and run on the Batch VMs
docker.enabled = true

// Keep a full audit trail (good for clinical provenance)
timeline.enabled = true
report.enabled   = true
trace.enabled    = true
dag.enabled      = true
