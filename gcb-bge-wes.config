/*
 * Google Batch profile — nf-core/sarek WES variant-calling FROM CRAM (BGE exome arm)
 * ---------------------------------------------------------------------------------
 * Reuses the sarek-clinical Google Cloud setup (project intergenica, region
 * us-central1, Spot VMs, GATK.GRCh38). Differs from sarek-clinical/gcb.config in
 * that it starts from already-aligned CRAMs (--step variant_calling) and restricts
 * to exome target intervals (--wes), so no re-alignment / BQSR is done.
 *
 * Use:  nextflow run nf-core/sarek -r 3.8.1 -profile docker -c gcb-bge-wes.config \
 *         --step variant_calling --input samplesheet.csv --intervals <targets> \
 *         --outdir gs://intergenica-sarek-clinical/bge-wes/results
 * (NXF_SYNTAX_PARSER=v1 is required — set by sarek-clinical/env.sh.)
 */

params {
    genome = 'GATK.GRCh38'                 // matches Broad/Terra BGE CRAM reference (Homo_sapiens_assembly38)
    tools  = 'deepvariant,strelka,freebayes,haplotypecaller'
    wes    = true                          // exome mode (Strelka --exome, no WGS-only metrics)
    // input / outdir / intervals / step are passed on the command line
}

// Run every task on Google Batch (Spot)
process {
    executor       = 'google-batch'
    resourceLimits = [ cpus: 32, memory: 120.GB, time: 24.h ]
    errorStrategy  = { task.exitStatus in [8,10,14,50001,50002] ? 'retry' : 'finish' }
    maxRetries     = 3                      // important for Spot reclaims
}

// Scratch in the bucket, namespaced so it never collides with the WGS work dir
workDir = 'gs://intergenica-sarek-clinical/bge-wes/work'

google {
    project  = 'intergenica'
    location = 'us-central1'
    batch {
        spot         = true
        bootDiskSize = 100.GB
    }
}

docker.enabled   = true
timeline.enabled = true
report.enabled   = true
trace.enabled    = true
dag.enabled      = true
