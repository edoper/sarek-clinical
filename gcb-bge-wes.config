/*
 * Google Batch profile — nf-core/sarek WES variant-calling FROM CRAM (BGE exome arm)
 * ---------------------------------------------------------------------------------
 * Reuses the sarek-clinical Google Cloud setup (project intergenica, region
 * us-central1, Spot VMs, GATK.GRCh38). Differs from sarek-clinical/gcb.config in
 * that it starts from already-aligned CRAMs (--step variant_calling) and restricts
 * to exome target intervals (--wes), so no re-alignment / BQSR is done.
 *
 * Use:  nextflow run nf-core/sarek -r 3.8.1 -profile docker -c gcb-bge-wes.config \
 *         --step variant_calling --input samplesheet.csv --intervals <targets> \
 *         --outdir gs://intergenica-sarek-clinical/bge-wes/results
 * (NXF_SYNTAX_PARSER=v1 is required — set by sarek-clinical/env.sh.)
 */

params {
    genome = 'GATK.GRCh38'                 // matches Broad/Terra BGE CRAM reference (Homo_sapiens_assembly38)
    tools  = 'deepvariant,strelka,freebayes,haplotypecaller'
    wes    = true                          // exome mode (Strelka --exome, no WGS-only metrics)
    // Pre-staged reference in our bucket (skips the slow S3 igenomes pull for the big files);
    // remaining GATK resources still come from --genome GATK.GRCh38.
    fasta     = 'gs://intergenica-sarek-clinical/refs/GATK.GRCh38/Homo_sapiens_assembly38.fasta'
    fasta_fai = 'gs://intergenica-sarek-clinical/refs/GATK.GRCh38/Homo_sapiens_assembly38.fasta.fai'
    dict      = 'gs://intergenica-sarek-clinical/refs/GATK.GRCh38/Homo_sapiens_assembly38.dict'
    dbsnp     = 'gs://intergenica-sarek-clinical/refs/GATK.GRCh38/Homo_sapiens_assembly38.dbsnp138.vcf.gz'
    dbsnp_tbi = 'gs://intergenica-sarek-clinical/refs/GATK.GRCh38/Homo_sapiens_assembly38.dbsnp138.vcf.gz.tbi'
    // input / outdir / intervals / step are passed on the command line
}

// Cap concurrent tasks. Without this, dispatch is unbounded: the 56-sample EPIG run
// (2026-07-19) put 224 jobs in flight at once and blew the us-central1
// IN_USE_ADDRESSES quota (limit 69 — every Batch VM takes an external IP), flooding
// the log with CODE_GCE_QUOTA_EXCEEDED. Mirrors gcb.config. Raise if quota is higher.
executor {
    queueSize = 40
}

// Run every task on Google Batch (Spot)
process {
    executor       = 'google-batch'
    resourceLimits = [ cpus: 32, memory: 120.GB, time: 24.h ]
    // Retry the whole Google Batch 5000x class — these are INFRASTRUCTURE failures
    // (VM recreated / preempted / rebooted), not data errors, and the task never ran
    // (a failed workdir holds only .command.sh/.command.run — no .command.err, no
    // output), so a retry has nothing partial to trip over.
    // 50006 ("VM is recreated during task execution") was absent from this list and
    // aborted the entire 56-sample EPIG cohort 9 min in on a single Spot reclaim.
    // Over that night 29 tasks were reclaimed and all recovered once widened.
    errorStrategy  = { task.exitStatus in [8,10,14,50001,50002,50003,50004,50005,50006,50007] ? 'retry' : 'finish' }
    maxRetries     = 6                      // Spot-reclaim insurance for large batches
}

// Scratch in the bucket, namespaced so it never collides with the WGS work dir
workDir = 'gs://intergenica-sarek-clinical/bge-wes/work'

google {
    project  = 'intergenica'
    location = 'us-central1'
    batch {
        spot         = true
        bootDiskSize = 100.GB
    }
}

docker.enabled   = true
timeline.enabled = true
report.enabled   = true
trace.enabled    = true
dag.enabled      = true
